DB_URL=jdbc:postgresql://your-db-host:5432/your-db-name
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password

GEMINI_API_KEY=your-gemini-api-key
GEMINI_OPENAI_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_NATIVE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash

REDIS_URL=rediss://default:your-redis-password@your-redis-host:6379
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_TIMEOUT=2s
REDIS_SSL_ENABLED=true

JWT_SECRET=replace-with-a-long-random-secret
APP_COOKIES_SECURE=true
APP_CORS_ALLOWED_ORIGIN=https://your-frontend-domain.com
